# Forge Environment Configuration
# Copy to .env and fill in your values
# NEVER commit .env to version control

# ── Core ──────────────────────────────────────────────────────
FORGE_ENVIRONMENT=development
FORGE_DEBUG=false
FORGE_LOG_LEVEL=INFO
FORGE_LOG_FORMAT=json

# ── Secrets (CRITICAL: Use strong values in production) ───────
FORGE_JWT_SECRET=change-me-to-at-least-32-characters-now
FORGE_API_KEY=your-secure-api-key-here
FORGE_ENCRYPTION_KEY=your-32-byte-encryption-key-here

# ── Database ──────────────────────────────────────────────────
FORGE_DATABASE_BACKEND=postgresql
FORGE_DATABASE_URL=postgresql+asyncpg://forge:password@localhost:5432/forge
FORGE_DATABASE_POOL_SIZE=10
FORGE_DATABASE_MAX_OVERFLOW=20

# ── Redis ─────────────────────────────────────────────────────
FORGE_REDIS_URL=redis://localhost:6379/0
FORGE_REDIS_POOL_MAX_CONNECTIONS=50

# ── BGI Trident ───────────────────────────────────────────────
FORGE_TRIDENT_MODE=fallback_rules
FORGE_TRIDENT_URL=http://localhost:8080
FORGE_TRIDENT_TIMEOUT=10.0

# ── Observability ─────────────────────────────────────────────
FORGE_OTEL_EXPORTER_ENDPOINT=http://localhost:4317
FORGE_SENTRY_DSN=
FORGE_SENTRY_ENVIRONMENT=development
FORGE_PROMETHEUS_PORT=9090

# ── Rate Limiting ─────────────────────────────────────────────
FORGE_RATE_LIMIT_REQUESTS=100
FORGE_RATE_LIMIT_WINDOW=60
FORGE_RATE_LIMIT_BURST=10

# ── Governance ────────────────────────────────────────────────
FORGE_GOVERNANCE_AUDIT_LOG_PATH=/var/log/forge/audit.log
FORGE_GOVERNANCE_AUTO_APPROVE_THRESHOLD=0.95

# ── MCP Integrations ──────────────────────────────────────────
FORGE_MCP_GITHUB_TOKEN=
FORGE_MCP_JIRA_TOKEN=
FORGE_MCP_JIRA_EMAIL=
FORGE_MCP_AWS_ACCESS_KEY_ID=
FORGE_MCP_AWS_SECRET_ACCESS_KEY=
FORGE_MCP_DATADOG_API_KEY=
